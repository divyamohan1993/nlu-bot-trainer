# NLU Bot Trainer Configuration
NEXT_PUBLIC_APP_NAME=NLU Bot Trainer
NEXT_PUBLIC_APP_VERSION=1.0.0

# Claude Code Sub-agents Configuration
# Sub-agents are ALWAYS enabled by default in Claude Code.
# To DISABLE background tasks (forces sub-agents to run in foreground):
# CLAUDE_CODE_DISABLE_BACKGROUND_TASKS=1
#
# Sub-agent context compaction threshold (default ~95%):
# CLAUDE_AUTOCOMPACT_PCT_OVERRIDE=95
CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1

# NLU Engine settings
NEXT_PUBLIC_DEFAULT_CONFIDENCE_THRESHOLD=0.65
NEXT_PUBLIC_MAX_TRAINING_EXAMPLES=10000

# Google Gemini API Key for synthetic data generation
# Get one at https://aistudio.google.com/apikey
# Server-side only — NEVER prefix with NEXT_PUBLIC_
# GOOGLE_API_KEY=your-gemini-api-key-here

# NVD API Key for CVE ID Lookup (optional)
# Without key: 5 requests per 30 seconds
# With key: 50 requests per 30 seconds
# Get one (free) at https://nvd.nist.gov/developers/request-an-api-key
# NVD_API_KEY=your-nvd-api-key-here
